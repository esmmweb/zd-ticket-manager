#!/bin/bash

# --- Configuration ---
# Load Zendesk credentials from .env file in the same directory as this script.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -f "$SCRIPT_DIR/.env" ]; then
  source "$SCRIPT_DIR/.env"
else
  echo "Error: .env file not found at $SCRIPT_DIR/.env"
  exit 1
fi

# --- Helper: business days calculation ---
# Returns the number of calendar days needed to advance N business days (Mon-Fri).
add_business_days() {
  local n=$1
  local count=0
  local offset=0
  while [ "$count" -lt "$n" ]; do
    offset=$((offset + 1))
    local dow
    dow=$(date -v+${offset}d "+%u")  # 1=Mon ... 5=Fri, 6=Sat, 7=Sun
    if [ "$dow" -le 5 ]; then
      count=$((count + 1))
    fi
  done
  echo "$offset"
}

# --- Usage ---
usage() {
  cat <<EOF
Usage: ./create_ticket [OPTIONS]

Run without options to use interactive prompts.

Options:
  -s, --site <name>         Pantheon site name
  -t, --template <type>     Template type: autopilot | approval | manual | external
  -e, --email <address>     Requester email address
      --subject <text>      Custom ticket subject (overrides auto-generated subject)
      --vrt <url>           VRT report URL (required for autopilot template)
  -n, --non-interactive     Disable all prompts; exit with error if required values are missing
  -h, --help                Show this help message

Examples:
  # Interactive mode (default)
  ./create_ticket

  # Non-interactive / webhook-friendly
  ./create_ticket --non-interactive \\
    --site mysite \\
    --template autopilot \\
    --email client@example.com \\
    --vrt "https://vrt.example.com/report"
EOF
  exit 0
}

# --- Parse flags ---
NON_INTERACTIVE=false
FLAG_SITE=""
FLAG_TEMPLATE=""
FLAG_EMAIL=""
FLAG_SUBJECT=""
FLAG_VRT=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -s|--site)            FLAG_SITE="$2";     shift 2 ;;
    -t|--template)        FLAG_TEMPLATE="$2"; shift 2 ;;
    -e|--email)           FLAG_EMAIL="$2";    shift 2 ;;
    --subject)            FLAG_SUBJECT="$2";  shift 2 ;;
    --vrt)                FLAG_VRT="$2";      shift 2 ;;
    -n|--non-interactive) NON_INTERACTIVE=true; shift ;;
    -h|--help)            usage ;;
    *) echo "Unknown option: $1"; echo ""; usage ;;
  esac
done

# --- Helper: resolve a value from a flag or interactive prompt ---
# Usage: prompt_or_flag <flag_value> <prompt_text> <variable_name>
prompt_or_flag() {
  local flag_val="$1"
  local prompt="$2"
  local result_var="$3"

  if [ -n "$flag_val" ]; then
    printf -v "$result_var" '%s' "$flag_val"
  elif [ "$NON_INTERACTIVE" = "true" ]; then
    echo "Error: --$(echo "$result_var" | tr '[:upper:]' '[:lower:]') is required in non-interactive mode."
    exit 1
  else
    read -p "$prompt" "$result_var"
  fi
}

# --- Site name ---
prompt_or_flag "$FLAG_SITE" "What's the site name? " SITE_NAME

# --- Template selection ---
if [ -n "$FLAG_TEMPLATE" ]; then
  case "$FLAG_TEMPLATE" in
    autopilot) TEMPLATE_OPTION=1 ;;
    manual)    TEMPLATE_OPTION=2 ;;
    approval)  TEMPLATE_OPTION=3 ;;
    external)  TEMPLATE_OPTION=4 ;;
    *)
      echo "Error: Invalid template '$FLAG_TEMPLATE'. Valid options: autopilot | approval | manual | external"
      exit 1
      ;;
  esac
elif [ "$NON_INTERACTIVE" = "true" ]; then
  echo "Error: --template is required in non-interactive mode."
  exit 1
else
  echo ""
  echo "What's the template?"
  echo "  1) Autopilot"
  echo "  2) Manual"
  echo "  3) Wait for Approval"
  echo "  4) External"
  echo ""
  read -p "Select an option (1-4): " TEMPLATE_OPTION
fi

# --- Template-specific logic ---
case "$TEMPLATE_OPTION" in
  1)
    TEMPLATE_NAME="managed_updates"

    echo ""
    echo "Fetching site UUID for '$SITE_NAME'..."
    UUID=$(terminus site:info "$SITE_NAME" --field=ID 2>/dev/null | tr -d '[:space:]')
    if [ -z "$UUID" ]; then
      echo "Error: Could not retrieve UUID for site '$SITE_NAME'."
      echo "Make sure terminus is installed and you are authenticated (terminus auth:login)."
      exit 1
    fi

    echo "Fetching primary domain for '${SITE_NAME}.live'..."
    PRIMARY_DOMAIN=$(terminus domain:list "${SITE_NAME}.live" --format=json 2>/dev/null | jq -r 'to_entries[] | select(.value.primary == true) | .key')
    if [ -z "$PRIMARY_DOMAIN" ]; then
      echo "Warning: Could not retrieve primary domain."
      PRIMARY_DOMAIN="[domain]"
    fi

    AUTOPILOT_URL="https://dashboard.pantheon.io/sites/${UUID}#autopilot"
    SITE_REVIEW_URL="https://autopilot-${SITE_NAME}.pantheonsite.io/"

    if [ "$NON_INTERACTIVE" = "false" ]; then
      echo "Autopilot URL: $AUTOPILOT_URL"
      echo "Site review URL: $SITE_REVIEW_URL"
      echo ""
    fi

    prompt_or_flag "$FLAG_VRT" "VRT report: " VRT_REPORT_URL
    ;;
  2)
    echo "Manual template not yet implemented."
    exit 1
    ;;
  3)
    TEMPLATE_NAME="managed_updates"

    echo ""
    echo "Fetching primary domain for '${SITE_NAME}.live'..."
    PRIMARY_DOMAIN=$(terminus domain:list "${SITE_NAME}.live" --format=json 2>/dev/null | jq -r 'to_entries[] | select(.value.primary == true) | .key')
    if [ -z "$PRIMARY_DOMAIN" ]; then
      echo "Warning: Could not retrieve primary domain."
      PRIMARY_DOMAIN="[domain]"
    fi
    ;;
  4)
    echo "External template not yet implemented."
    exit 1
    ;;
  *)
    echo "Invalid option. Please select 1-4."
    exit 1
    ;;
esac

# --- Auto-calculate dates (business days only, skipping Sat/Sun) ---
DEPLOY_OFFSET=$(add_business_days 3)
REPLY_OFFSET=$(add_business_days 2)
DEPLOY_DATE=$(date -v+${DEPLOY_OFFSET}d "+%a, %b %d, '%y")
REPLY_BY_DATE=$(date -v+${REPLY_OFFSET}d "+%a, %b %d, '%y")

# --- Auto-generate subject for managed updates templates ---
if [ "$TEMPLATE_OPTION" = "1" ]; then
  AUTO_SUBJECT="${PRIMARY_DOMAIN} - Managed Updates Ready for Review - Deploy to LIVE on ${DEPLOY_DATE}."
elif [ "$TEMPLATE_OPTION" = "3" ]; then
  AUTO_SUBJECT="${PRIMARY_DOMAIN} - Managed Updates Ready for Review - Deploy upon Approval."
fi

# --- Load template ---
TEMPLATE_DIR="$SCRIPT_DIR/templates/$TEMPLATE_NAME"

VALUES_FILE="$TEMPLATE_DIR/values.env"
if [ -f "$VALUES_FILE" ]; then
  source "$VALUES_FILE"
fi

BODY_FILE=$(find "$TEMPLATE_DIR" -maxdepth 1 -name "*.txt" | head -n 1)
if [ -z "$BODY_FILE" ]; then
  echo "Error: No .txt body file found in $TEMPLATE_DIR"
  exit 1
fi

# --- Substitute placeholders ---
# Variables set via flags or auto-calculated above take precedence over values.env.
HTML_BODY=$(sed \
  -e "s|{{AUTOPILOT_URL}}|${AUTOPILOT_URL}|g" \
  -e "s|{{DEPLOY_DATE}}|${DEPLOY_DATE}|g" \
  -e "s|{{REPLY_BY_DATE}}|${REPLY_BY_DATE}|g" \
  -e "s|{{SITE_REVIEW_URL}}|${SITE_REVIEW_URL}|g" \
  -e "s|{{VRT_REPORT_URL}}|${VRT_REPORT_URL}|g" \
  -e "s|{{CORE_UPDATES}}|${CORE_UPDATES}|g" \
  -e "s|{{MODULE_UPDATES}}|${MODULE_UPDATES}|g" \
  -e "s|{{COMPOSER_UPDATES}}|${COMPOSER_UPDATES}|g" \
  -e "s|{{TESTED_URLS}}|${TESTED_URLS}|g" \
  "$BODY_FILE")

# --- Resolve subject ---
echo ""
if [ -n "$FLAG_SUBJECT" ]; then
  SUBJECT="$FLAG_SUBJECT"
elif [ -n "$AUTO_SUBJECT" ]; then
  if [ "$NON_INTERACTIVE" = "true" ]; then
    SUBJECT="$AUTO_SUBJECT"
  else
    echo "Auto-generated subject: $AUTO_SUBJECT"
    read -p "Press Enter to use this subject, or type a custom one: " CUSTOM_SUBJECT
    SUBJECT="${CUSTOM_SUBJECT:-$AUTO_SUBJECT}"
  fi
else
  if [ "$NON_INTERACTIVE" = "true" ]; then
    echo "Error: --subject is required for this template in non-interactive mode."
    exit 1
  fi
  read -p "Ticket subject: " SUBJECT
fi

prompt_or_flag "$FLAG_EMAIL" "Requester email: " REQUESTER_EMAIL

# --- Build and send ticket ---
# Construct the JSON payload using jq for safe encoding.
# html_body is used so that links and formatting render correctly in Zendesk.
JSON_PAYLOAD=$(jq -n \
  --arg subject "$SUBJECT" \
  --arg html_body "$HTML_BODY" \
  --arg email "$REQUESTER_EMAIL" \
  '{ticket: {subject: $subject, comment: {html_body: $html_body}, requester: {email: $email, name: $email}}}')

API_URL="https://${ZENDESK_SUBDOMAIN}.zendesk.com/api/v2/tickets.json"

echo ""
echo "Creating Zendesk ticket..."
curl "$API_URL" \
  -u "${ZENDESK_EMAIL}:${ZENDESK_API_TOKEN}" \
  -H "Content-Type: application/json" \
  -X POST \
  -d "$JSON_PAYLOAD"

echo -e "\nDone."
