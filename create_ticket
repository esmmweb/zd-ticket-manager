#!/bin/bash

# --- Configuration ---
# Load environment variables from .env file in the same directory as this script.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -f "$SCRIPT_DIR/.env" ]; then
  source "$SCRIPT_DIR/.env"
else
  echo "Error: .env file not found at $SCRIPT_DIR/.env"
  exit 1
fi

# --- Script Logic ---

# Check if all required arguments are provided.
if [ "$#" -ne 2 ]; then
    echo "Usage: $0 \"<ticket subject>\" \"<requester_email>\""
    echo "Example: $0 \"Managed Updates Ready for Review\" \"user@example.com\""
    exit 1
fi

# Assign command-line arguments to variables for clarity.
SUBJECT="$1"
REQUESTER_EMAIL="$2"

# Build the ticket body from the template, substituting placeholders with .env values.
TEMPLATE_FILE="$SCRIPT_DIR/ticket_body_template.txt"
if [ ! -f "$TEMPLATE_FILE" ]; then
    echo "Error: Template file not found at $TEMPLATE_FILE"
    exit 1
fi

COMMENT_BODY=$(sed \
  -e "s|{{DEPLOY_DATE}}|${DEPLOY_DATE}|g" \
  -e "s|{{REPLY_BY_DATE}}|${REPLY_BY_DATE}|g" \
  -e "s|{{SITE_REVIEW_URL}}|${SITE_REVIEW_URL}|g" \
  -e "s|{{VRT_REPORT_URL}}|${VRT_REPORT_URL}|g" \
  -e "s|{{CORE_UPDATES}}|${CORE_UPDATES}|g" \
  -e "s|{{MODULE_UPDATES}}|${MODULE_UPDATES}|g" \
  -e "s|{{COMPOSER_UPDATES}}|${COMPOSER_UPDATES}|g" \
  -e "s|{{TESTED_URLS}}|${TESTED_URLS}|g" \
  "$TEMPLATE_FILE")

# Construct the JSON payload using jq for safe encoding.
JSON_PAYLOAD=$(jq -n \
  --arg subject "$SUBJECT" \
  --arg body "$COMMENT_BODY" \
  --arg email "$REQUESTER_EMAIL" \
  '{ticket: {subject: $subject, comment: {body: $body}, requester: {email: $email, name: $email}}}')

# The API endpoint for creating tickets.
API_URL="https://${ZENDESK_SUBDOMAIN}.zendesk.com/api/v2/tickets.json"

# Make the API call using curl.
echo "Creating Zendesk ticket..."
curl "$API_URL" \
  -u "${ZENDESK_EMAIL}:${ZENDESK_API_TOKEN}" \
  -H "Content-Type: application/json" \
  -X POST \
  -d "$JSON_PAYLOAD"

echo -e "\nDone."
