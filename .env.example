# Zendesk credentials
ZENDESK_SUBDOMAIN=yoursubdomain
ZENDESK_EMAIL=you@example.com/token
ZENDESK_API_TOKEN=your_api_token_here

# Pantheon machine token — used by the Next.js webhook to look up the primary domain
# Generate at: https://dashboard.pantheon.io/personal-settings/machine-tokens
PANTHEON_MACHINE_TOKEN=your_machine_token_here

# Secret used to authenticate incoming webhook POST requests
# Set to a long random string and pass it as the x-webhook-secret request header
WEBHOOK_SECRET=your_webhook_secret_here
