#!/bin/bash

# --- Configuration ---
# Load environment variables from .env file in the same directory as this script.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -f "$SCRIPT_DIR/.env" ]; then
  source "$SCRIPT_DIR/.env"
else
  echo "Error: .env file not found at $SCRIPT_DIR/.env"
  exit 1
fi

# --- Script Logic ---

# Check if all required arguments are provided.
if [ "$#" -ne 3 ]; then
    echo "Usage: $0 \"<ticket subject>\" \"<ticket body>\" \"<requester_email>\""
    echo "Example: $0 \"Server is down\" \"The main web server is not responding.\" \"user@example.com\""
    exit 1
fi

# Assign command-line arguments to variables for clarity.
SUBJECT="$1"
COMMENT_BODY="$2"
REQUESTER_EMAIL="$3"

# Construct the JSON payload for the new ticket.
# We use printf for safe string formatting.
JSON_PAYLOAD=$(printf '{
  "ticket": {
    "subject": "%s",
    "comment": {
      "body": "%s"
    },
    "requester": {
      "email": "%s",
      "name": "%s"
    }
  }
}' "$SUBJECT" "$COMMENT_BODY" "$REQUESTER_EMAIL" "$REQUESTER_EMAIL")

# The API endpoint for creating tickets.
API_URL="https://${ZENDESK_SUBDOMAIN}.zendesk.com/api/v2/tickets.json"

# Make the API call using curl.
echo "Creating Zendesk ticket..."
curl "$API_URL" \
  -u "${ZENDESK_EMAIL}:${ZENDESK_API_TOKEN}" \
  -H "Content-Type: application/json" \
  -X POST \
  -d "$JSON_PAYLOAD"

echo -e "\nDone."
